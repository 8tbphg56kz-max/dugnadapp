@page "/login"
@layout LoginLayout
@using DugnadApp.Data
@using DugnadApp.Models
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using DugnadApp.Services
@inject EmailService EmailService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject DugnadDbContext Db

<div class="d-flex flex-column align-items-center"
     style="padding-top:8vh; min-height:100vh;">

    <div class="text-center mb-5">
        <h1 class="display-5 fw-semibold">DugnadApp</h1>

        <p class="text-muted">
            Registrer dugnadstimer enkelt og sikkert
        </p>
    </div>

    <div class="card shadow p-4"
         style="max-width:450px; width:100%;">
        <h4 class="text-center mb-3">Logg inn</h4>

        @if (!KodeSendt)
        {
            <InputText class="form-control mb-3"
                       @bind-Value="Epost"
                       placeholder="E-post" />

            <button class="btn btn-primary w-100"
                    @onclick="SendKode">
                Send kode
            </button>
        }
        else
        {
            <div class="text-center mb-3">

                <h6>
                    Hei @Fornavn!
                </h6>

                <p>
                    Vi har sendt en kode til
                    <strong>@MaskerEpost(Epost)</strong>
                </p>

                <p class="text-muted">
                    Hent koden fra innboksen din og skriv den inn nedenfor.
                </p>
            </div>

            <InputText class="form-control mb-3"
                       @bind-Value="Kode"
                       placeholder="6-sifret kode" />

            <button class="btn btn-success w-100 mb-2"
                    @onclick="LoggInn">
                Logg inn
            </button>            
        }

        @if (!string.IsNullOrWhiteSpace(Melding))
        {
            <div class="alert alert-danger mt-3">
                @Melding
            </div>
        }
    </div>

    @if (!KodeSendt)
    {
        <div class="card border-0 shadow-sm mt-4 p-4"
             style="max-width:450px; width:100%;">

            <h5 class="mb-3">
                📢 Informasjon
            </h5>

            <p>
                Logg inn og registrer timer hver gang du har
                utført dugnadsarbeid.
            </p>

            <p>
                Styret bruker opplysningene kun til
                administrasjon av dugnadstimene.
            </p>

            <p class="mb-0">
                Data slettes etter endt dugnadsår.
            </p>

        </div>
    }

</div>
@code {
    private string Fornavn = "";
    private string Epost = "";
    private string Melding = "";
    private string Kode = "";
    private bool KodeSendt = false;   

    private async Task SendKode()
    {
        var beboer = await Db.Beboere
            .FirstOrDefaultAsync(x => x.Epost.ToLower() == Epost.ToLower());

        if (beboer == null)
        {
            Melding = "Fant ingen beboer med denne e-postadressen.";
            return;
        }

        Fornavn = beboer.Fornavn;

        var kode = Random.Shared
            .Next(100000, 999999)
            .ToString();

        var loginCode = new LoginCode
        {
            Epost = beboer.Epost,
            Kode = kode,
            Opprettet = DateTime.UtcNow,
            Utloper = DateTime.UtcNow.AddMinutes(15),
            Brukt = false
        };

        Db.LoginCoder.Add(loginCode);
        await Db.SaveChangesAsync();

        KodeSendt = true;
        Melding = "";

        await EmailService.SendLoginCodeAsync(
    beboer.Epost,
    kode);
    }

    private void StartPåNytt()
    {
        KodeSendt = false;
        Kode = "";
    }

    private async Task LoggInn()
    {
        var loginCode = await Db.LoginCoder
            .Where(x => x.Epost.ToLower() == Epost.ToLower())
            .Where(x => x.Kode == Kode)
            .Where(x => !x.Brukt)
            .Where(x => x.Utloper > DateTime.UtcNow)
            .OrderByDescending(x => x.Opprettet)
            .FirstOrDefaultAsync();

        if (loginCode == null)
        {
            Melding = "Ugyldig eller utløpt kode.";
            return;
        }

        loginCode.Brukt = true;        

        await Db.SaveChangesAsync();

        Navigation.NavigateTo(
            $"/auth/login?epost={Uri.EscapeDataString(Epost)}",
            true);
    }

    private string MaskerEpost(string epost)
    {
        if (string.IsNullOrWhiteSpace(epost))
            return "";

        var deler = epost.Split('@');

        if (deler.Length != 2)
            return epost;

        var navn = deler[0];
        var domene = deler[1];

        if (navn.Length <= 2)
            return $"{navn[0]}***@{domene}";

        return $"{navn.Substring(0, 2)}***@{domene}";
    }
}
