@page "/timeregistrering"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using DugnadApp.Models
@using DugnadApp.Data
@using System.Security.Claims
@using Microsoft.AspNetCore.Http
@inject DugnadDbContext DbContext
@inject IHttpContextAccessor HttpContextAccessor

<div class="d-flex align-items-center gap-3 mb-4">

    <div>
        <h2 class="fw-bold mb-1">
            Registrering av <span class="dugnad-gronn">dugnadstimer</span>
        </h2>

        <p class="text-muted mb-0">
            Fyll ut skjemaet under for å registrere din dugnadsinnsats
        </p>
    </div>

    <img src="/Images/Startside.png"
         alt="DugnadApp"
         class="img-fluid"
         style="max-width:80px;" />
</div>

<div class="mb-3">
    <label class="form-label fw-bold">
        Innlogget som: @Navn
    </label>
</div>

<div class="card border-success shadow-sm mb-4 statistik-kort">
    <div class="card-body text-center">

        <div class="fs-4 mb-1">
            🏆
        </div>

        <div class="text-muted small">
            Totalt registrert
        </div>

        <div class="fw-bold text-success display-6">
            @TotaltRegistrerteTimerTekst
        </div>

        <div class="text-muted small">
            dugnadstimer
        </div>

        @if (SisteRegistrering is not null)
        {
            <hr />

            <div class="small text-muted">
                Siste registrering
            </div>

            <div class="fw-semibold">
                @SisteRegistrering.RegistrertDato.ToString("dd.MM.yyyy")
            </div>
        }

    </div>
</div>

<div class="mb-3">
    @if (NyDeltakelse.DugnadId > 0)
    {
        <label class="form-label fw-bold label-dugnad">Dugnad</label>
    }

        <select class="form-select dugnad" @bind="NyDeltakelse.DugnadId">
        <option value="0">-- Velg dugnad --</option>

        @foreach (var dugnad in Dugnader)
        {
            <option value="@dugnad.Id">@dugnad.Navn</option>
        }
    </select>
</div>

@if (ValgtDugnadKreverBeskrivelse)
{
    <div class="mb-3">
          <label class="form-label fw-bold label-beskrivelse">
            Beskrivelse (stikkord)
        </label>

        <select class="form-select dugnad"
                value="@NyDeltakelse.DugnadId"
                @onchange="DugnadEndret"
                placeholder="f.eks. klippet hekk, luket bed, ryddet bod" />
    </div>
}

<div class="mb-3">
    @if (NyDeltakelse.Timer > 0)
    {
        <label class="form-label fw-bold label-timer">Timer</label>
    }

        <select class="form-select timer" @bind="NyDeltakelse.Timer">
        <option value="0">-- Velg timer --</option>
        <option value="0,5">0,5 time</option>
        <option value="1">1,0 time</option>
        <option value="1,5">1,5 time</option>
        <option value="2">2,0 timer</option>
        <option value="2,5">2,5 timer</option>
        <option value="3">3,0 timer</option>
        <option value="3,5">3,5 timer</option>
        <option value="4">4,0 timer</option>
        <option value="4,5">4,5 timer</option>
        <option value="5">5,0 timer</option>
        <option value="5,5">5,5 timer</option>
        <option value="6">6,0 timer</option>
    </select>
</div>

<button class="btn btn-success text-white"
        @onclick="Lagre"
        disabled="@(!KanLagre)">
    Registrer →
</button>

@if (!string.IsNullOrEmpty(Melding))
{
    <div class="alert alert-success mt-3">
        @Melding
    </div>
}

@if (MineDeltakelser.Any())
{
    <h4 class="mt-4">
        Mine registrerte dugnadstimer
        <span class="text-muted">
            (@MineDeltakelser.Count registreringer)
        </span>
    </h4>

    <div class="table-responsive">
    <table class="table table-table">
        <thead>
            <tr>
                <th>Dato</th>
                <th>Dugnad</th>
                    <th class="d-none d-md-table-cell">Beskrivelse</th>
                <th>Timer</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in MineDeltakelser)
            {
                var dugnadNavn = Dugnader
                    .FirstOrDefault(x => x.Id == d.DugnadId)?.Navn;

                <tr>
                    <td>@d.RegistrertDato.ToString("dd.MM.yyyy")</td>
                    <td>@dugnadNavn</td>
                        <td class="d-none d-md-table-cell">
                        @(string.IsNullOrWhiteSpace(d.Beskrivelse)
                            ? "-"
                            : d.Beskrivelse)
                    </td>
                    <td>@d.Timer</td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}

@code {
    private List<Dugnad> Dugnader = new();

    private Deltakelse NyDeltakelse = new();

    private decimal TotaltRegistrerteTimer =>
    MineDeltakelser.Sum(d => d.Timer);

    private Deltakelse? SisteRegistrering =>
    MineDeltakelser
        .OrderByDescending(d => d.RegistrertDato)
        .FirstOrDefault();

    private void DugnadEndret(ChangeEventArgs e)
    {
        NyDeltakelse.DugnadId = int.Parse(e.Value?.ToString() ?? "0");

        if (!ValgtDugnadKreverBeskrivelse)
        {
            NyDeltakelse.Beskrivelse = "";
        }
    }

    private string TotaltRegistrerteTimerTekst =>
        TotaltRegistrerteTimer % 1 == 0
            ? TotaltRegistrerteTimer.ToString("0")
            : TotaltRegistrerteTimer.ToString("0.0");

    private List<Deltakelse> MineDeltakelser = new();

    private string Melding = "";
    private string? Navn;
    private string? Fornavn;

    private bool KanLagre =>
    NyDeltakelse.BeboerId > 0 &&
    NyDeltakelse.DugnadId > 0 &&
    NyDeltakelse.Timer > 0;

    private bool ValgtDugnadKreverBeskrivelse =>
   Dugnader.FirstOrDefault(d => d.Id == NyDeltakelse.DugnadId)
       ?.KreverBeskrivelse ?? false;

    protected override async Task OnInitializedAsync()
    {
     Dugnader = await DbContext.Dugnader
    .Where(d => d.Aktiv)
    .OrderBy(d => d.Navn)
    .ToListAsync();

       

var beboerIdClaim =
    HttpContextAccessor.HttpContext?.User
        .FindFirst(ClaimTypes.NameIdentifier)?.Value;

if (int.TryParse(beboerIdClaim, out var beboerId))
{
    NyDeltakelse.BeboerId = beboerId;  
    MineDeltakelser = await DbContext.Deltakelser
                      .Where(d => d.BeboerId == NyDeltakelse.BeboerId)
                      .OrderByDescending(d => d.RegistrertDato)
                      .ToListAsync();
}       

var innloggetBeboer =
    await DbContext.Beboere
        .FirstOrDefaultAsync(b => b.Id == beboerId);

if (innloggetBeboer != null)
{
    Navn = $"{innloggetBeboer.Fornavn} {innloggetBeboer.Etternavn}";
            Fornavn = innloggetBeboer.Fornavn;
}
       
    }

    private async Task Lagre()
    {
        if (NyDeltakelse.BeboerId == 0 ||
            NyDeltakelse.DugnadId == 0 ||
            NyDeltakelse.Timer == 0)
        {
            Melding = "Alle felter må fylles ut.";
            return;
        }

        if (ValgtDugnadKreverBeskrivelse &&
    string.IsNullOrWhiteSpace(NyDeltakelse.Beskrivelse))
        {
            Melding = "Beskrivelse må fylles ut.";
            return;
        }

        NyDeltakelse.RegistrertDato = DateTime.UtcNow;

        DbContext.Deltakelser.Add(NyDeltakelse);

        await DbContext.SaveChangesAsync();
        MineDeltakelser.Insert(0, NyDeltakelse);

        var registrerteTimer = NyDeltakelse.Timer;
        var registrertDugnadId = NyDeltakelse.DugnadId;
        var beboerId = NyDeltakelse.BeboerId;

        Melding = "Dugnad registrert!";

        var dugnadNavn = Dugnader
    .FirstOrDefault(d => d.Id == registrertDugnadId)?.Navn;   
        
        Melding = $"✅ Takk {Fornavn}! " +
          $"{registrerteTimer} timer registrert på '{dugnadNavn}'.";

        NyDeltakelse = new Deltakelse
        {
            BeboerId = beboerId
        };

        StateHasChanged();

        await Task.Delay(5000);

        Melding = "";

        StateHasChanged();
    }      
}