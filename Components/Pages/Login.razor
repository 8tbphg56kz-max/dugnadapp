@page "/login"
@using System.ComponentModel.DataAnnotations
@using System.Security.Cryptography
@using DugnadApp.Data
@using DugnadApp.Models
@using DugnadApp.Services
@using Microsoft.EntityFrameworkCore

@inject EmailService EmailService
@inject DugnadDbContext DbContext

<PageTitle>Innlogging</PageTitle>

<h3>Innlogging for registrering av dugnadstimer</h3>

<EditForm Model="model" OnValidSubmit="SendLoginLink">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <InputText class="form-control"
                   @bind-Value="model.Epost"
                   placeholder="Skriv inn e-postadressen din" />
    </div>

    <button class="btn btn-success" type="submit">
        Logg inn
    </button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(SuksessMelding))
{
    <div class="alert alert-success mt-3">
        ✅ @SuksessMelding
    </div>
}

@if (!string.IsNullOrWhiteSpace(FeilMelding))
{
    <div class="alert alert-danger mt-3">
        ❌ @FeilMelding
    </div>
}

@code
{
    private readonly LoginModel model = new();

    private string? SuksessMelding;
    private string? FeilMelding;

    private async Task SendLoginLink()
    {
        ClearMessages();

        var beboer = await FindBeboerAsync(model.Epost);

        if (beboer is null)
        {
            await ShowErrorAsync(
                "Fant ingen beboer med denne e-postadressen.");

            return;
        }

        var token = await CreateLoginTokenAsync(beboer.Id);

        await SendLoginEmailAsync(model.Epost, token);

        await ShowSuccessAsync("E-post sendt til innboksen din!");
    }

    private async Task<Beboer?> FindBeboerAsync(string epost)
    {
        return await DbContext.Beboere
            .AsNoTracking()
            .FirstOrDefaultAsync(x => x.Epost == epost);
    }

    private async Task<string> CreateLoginTokenAsync(int beboerId)
    {
        var token = Convert.ToBase64String(
            RandomNumberGenerator.GetBytes(32));

        DbContext.LoginTokens.Add(new LoginToken
        {
            BeboerId = beboerId,
            Token = token,
            Opprettet = DateTime.UtcNow,
            Utloper = DateTime.UtcNow.AddMinutes(15),
            Brukt = false
        });

        await DbContext.SaveChangesAsync();

        return token;
    }

    private async Task SendLoginEmailAsync(string epost, string token)
    {
        var url =
            $"https://localhost:7061/magic-login?token={Uri.EscapeDataString(token)}";

        await EmailService.SendAsync(
            epost,
            "Innlogging til DugnadApp",
            $"""
            Hei!

            Du har bedt om innlogging til DugnadApp.

            Klikk på lenken under for å logge inn:

            {url}

            Lenken er gyldig i 15 minutter.

            Med vennlig hilsen
            DugnadApp
            """);
    }

    private async Task ShowSuccessAsync(string message)
    {
        SuksessMelding = message;
        FeilMelding = null;

        await HideMessagesAfterDelayAsync(clearEmail: true);
    }

    private async Task ShowErrorAsync(string message)
    {
        FeilMelding = message;
        SuksessMelding = null;

        await HideMessagesAfterDelayAsync(clearEmail: false);
    }

    private async Task HideMessagesAfterDelayAsync(bool clearEmail)
    {
        StateHasChanged();

        await Task.Delay(8000);

        ClearMessages();

        if (clearEmail)
        {
            model.Epost = string.Empty;
        }

        await InvokeAsync(StateHasChanged);
    }

    private void ClearMessages()
    {
        SuksessMelding = null;
        FeilMelding = null;
    }

    public class LoginModel
    {
        [Required(ErrorMessage = "E-post er påkrevd")]
        [EmailAddress(ErrorMessage = "Ugyldig e-postadresse")]
        public string Epost { get; set; } = string.Empty;
    }
}