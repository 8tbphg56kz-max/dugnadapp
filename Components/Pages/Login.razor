@page "/login"
@using DugnadApp.Data
@using DugnadApp.Models
@using Microsoft.EntityFrameworkCore
@using System.Security.Claims
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Authentication.Cookies
@using DugnadApp.Services
@inject EmailService EmailService
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager Navigation
@inject DugnadDbContext Db

<h3>Logg inn</h3>

<input @bind="Epost" placeholder="E-post" />

<button @onclick="SendKode">
    Send kode
</button>

@if (!string.IsNullOrEmpty(Melding))
{
    <p>@Melding</p>
}

@if (KodeSendt)
{
    <div class="mt-3">
        <input @bind="Kode" placeholder="6-sifret kode" />

        <button @onclick="LoggInn">
            Logg inn
        </button>
    </div>
}

@code {

    private string Epost = "";
    private string Melding = "";
    private string Kode = "";
    private bool KodeSendt = false;

    private async Task SendKode()
    {
        var beboer = await Db.Beboere
            .FirstOrDefaultAsync(x => x.Epost.ToLower() == Epost.ToLower());

        if (beboer == null)
        {
            Melding = "Fant ingen beboer med denne e-postadressen.";
            return;
        }

        var kode = Random.Shared
            .Next(100000, 999999)
            .ToString();

        var loginCode = new LoginCode
        {
            Epost = beboer.Epost,
            Kode = kode,
            Opprettet = DateTime.UtcNow,
            Utloper = DateTime.UtcNow.AddMinutes(15),
            Brukt = false
        };

        Db.LoginCoder.Add(loginCode);
        await Db.SaveChangesAsync();

        KodeSendt = true;

        Melding = "Vi har sendt en innlogingskode til e-postadressen din.";

        await EmailService.SendLoginCodeAsync(
    beboer.Epost,
    kode);
    }

    private async Task LoggInn()
    {
        var loginCode = await Db.LoginCoder
            .Where(x => x.Epost == Epost)
            .Where(x => x.Kode == Kode)
            .Where(x => !x.Brukt)
            .Where(x => x.Utloper > DateTime.UtcNow)
            .OrderByDescending(x => x.Opprettet)
            .FirstOrDefaultAsync();

        if (loginCode == null)
        {
            Melding = "Ugyldig eller utløpt kode.";
            return;
        }

        loginCode.Brukt = true;

        await Db.SaveChangesAsync();

        Navigation.NavigateTo(
            $"/auth/login?epost={Uri.EscapeDataString(Epost)}",
            true);
    }
}
