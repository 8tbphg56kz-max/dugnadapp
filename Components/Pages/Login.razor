@page "/login"
@using System.ComponentModel.DataAnnotations
@using DugnadApp.Data
@using DugnadApp.Models
@using Microsoft.EntityFrameworkCore
@using System.Security.Cryptography
@using DugnadApp.Services
@inject EmailService EmailService
@inject DugnadDbContext DbContext

<PageTitle>Innlogging</PageTitle>

<h3>Innlogging</h3>

<EditForm Model="@model" OnValidSubmit="SendLoginLink">
    <DataAnnotationsValidator />

    <div class="mb-3">
        <InputText class="form-control"
                   @bind-Value="model.Epost"
                   placeholder="Skriv inn e-postadressen din" />
    </div>

    <button class="btn btn-success" type="submit">
        Logg inn
    </button>
</EditForm>

@if (!string.IsNullOrWhiteSpace(SuksessMelding))
{
    <div class="alert alert-success mt-3">
        ✅ E-post sendt! Sjekk innboksen din og klikk på lenken i e-posten.
        Dersom e-posten ikke dukker opp innen et minutt, sjekk søppelpost.
    </div>
}

@if (!string.IsNullOrWhiteSpace(FeilMelding))
{
    <div class="alert alert-danger mt-3">
        ❌ @FeilMelding
    </div>
}

@code
{
    private LoginModel model = new();

    private string? Melding;
    private string? SuksessMelding;
    private string? FeilMelding;

    private async Task SendLoginLink()
    {
        var beboer = await DbContext.Beboere
            .FirstOrDefaultAsync(x => x.Epost == model.Epost);

        if (beboer == null)
{
    FeilMelding = "Fant ingen beboer med denne e-postadressen.";
    SuksessMelding = null;

    _ = Task.Run(() => SkjulMeldingEtter5Sekunder(false));

    return;
}
               
        var token = Convert.ToBase64String(
            RandomNumberGenerator.GetBytes(32));

        var loginToken = new LoginToken
        {
            BeboerId = beboer.Id,
            Token = token,
            Opprettet = DateTime.UtcNow,
            Utloper = DateTime.UtcNow.AddMinutes(15),
            Brukt = false
        };

        DbContext.LoginTokens.Add(loginToken);

        await DbContext.SaveChangesAsync();

        var url =
     $"https://localhost:7061/magic-login?token={Uri.EscapeDataString(token)}";

        await EmailService.SendAsync(
    model.Epost,
    "Innlogging til DugnadApp",
    $"""
Hei!

Du har bedt om innlogging til DugnadApp.

Klikk på lenken under for å logge inn:

{url}

Lenken er gyldig i 15 minutter.

Med vennlig hilsen
DugnadApp
""");

        SuksessMelding = "E-post sendt!";
        FeilMelding = null;

        _ = Task.Run(() => SkjulMeldingEtter5Sekunder(true));
    }

    private async Task SkjulMeldingEtter5Sekunder(bool tømEpostfelt)
    {
        await Task.Delay(8000);

        SuksessMelding = null;
        FeilMelding = null;

        if (tømEpostfelt)
        {
            model.Epost = string.Empty;
        }

        await InvokeAsync(StateHasChanged);
    }

    public class LoginModel
    {
        [Required]
        [EmailAddress]
        public string Epost { get; set; } = "";
    }
}
